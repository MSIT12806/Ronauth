{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "JwtSettings": {
    "Issuer": "RonAuth",
    "Audience": "RonFlow.Client",
    "SigningKey": "RonAuth-Development-Signing-Key-For-Local-Only-1234567890",
    "AccessTokenLifetimeMinutes": 30,
    "TemporaryTokenLifetimeMinutes": 10
  },
  "CrossSiteSession": {
    "CookieName": "ronauth.sid",
    "SessionLifetimeMinutes": 480,
    "CookieSecure": false
  },
  "PasswordPolicy": {
    "MinimumLength": 8,
    "RequireUppercase": true,
    "RequireLowercase": true,
    "RequireDigit": true,
    "RequireNonAlphanumeric": true,
    "MinimumPasswordAgeDays": 0,
    "MaximumPasswordAgeDays": 90,
    "PasswordHistoryCount": 5
  },
  "Persistence": {
    "DatabasePath": "App_Data/ronauth.db"
  },
  "AllowedHosts": "*"
}
